---
import '../styles/global.css';
import '@fontsource/source-serif-4/400.css';
import '@fontsource/source-serif-4/600.css';
import '@fontsource/source-sans-3/400.css';
import '@fontsource/source-sans-3/500.css';
import '@fontsource/source-sans-3/600.css';

import { person } from '../data/cv';
import { contact } from '../data/contact';
import { academicIds, cityUStaffProfileUrl, googleScholarProfileUrl } from '../data/profiles';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const assetBase = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: person.fullDisplayName,
  jobTitle: person.title,
  worksFor: {
    '@type': 'Organization',
    name: 'City University of Macau',
  },
  email: contact.cityu,
  telephone: person.officePhone,
  sameAs: [
    googleScholarProfileUrl,
    cityUStaffProfileUrl,
    academicIds.orcid.href,
    academicIds.scopus.href,
    academicIds.webOfScience.href,
  ],
  url: Astro.site ? new URL('/', Astro.site).href : canonicalURL.href,
};
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Theme tokens: fallback if main stylesheet is slow or blocked so layout is never plain white-on-black. -->
    <style is:inline>
      html {
        background-color: #eceae5;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background-color: #eceae5;
        color: #1d2731;
        font-family:
          'Source Sans 3',
          system-ui,
          -apple-system,
          'Segoe UI',
          Roboto,
          sans-serif;
      }
    </style>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${assetBase}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-secondary-faint focus:px-3 focus:py-2 focus:text-ink focus:outline-none focus:ring-2 focus:ring-secondary"
    >
      Skip to main content
    </a>
    <script is:inline>
      (() => {
        try {
          const key = 'visit-tracked-v1';
          if (sessionStorage.getItem(key)) return;
          sessionStorage.setItem(key, '1');

          const fn = (import.meta && import.meta.env && import.meta.env.PUBLIC_SUPABASE_TRACK_VISIT_URL) || '';
          if (!fn) return;
          fetch(fn, { method: 'POST', mode: 'cors' }).catch(() => {});
        } catch {}
      })();
    </script>
    <slot />
  </body>
</html>
