---
import { navLinks } from '../data/cv';
---

<header
  class="sticky top-0 z-40 border-b border-border/80 bg-page/90 backdrop-blur-md"
  style="box-shadow: 0 1px 0 0 var(--color-accent-pink);"
>
  <div class="mx-auto flex max-w-3xl flex-wrap items-center justify-between gap-3 px-4 py-3 sm:px-6">
    <p class="font-serif text-lg font-semibold text-ink">April Jiawei Zhang</p>
    <nav aria-label="Primary" class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted">
      {
        navLinks.map(({ href, label }) => (
          <a
            href={href}
            class="font-medium text-primary no-underline decoration-2 hover:bg-accent-yellow/40 hover:text-ink rounded px-1 py-0.5 transition-colors"
          >
            {label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
