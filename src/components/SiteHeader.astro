---
import { navItems } from '../data/nav';
import { withBase } from '../utils/paths';

function normPath(pathname: string): string {
  const x = pathname.replace(/\/$/, '') || '/';
  return x;
}

const current = normPath(Astro.url.pathname);

function isActive(href: string): boolean {
  const target = normPath(new URL(href, Astro.url).pathname);
  if (target === '/') return current === '/';

  for (const section of ['/research', '/teaching', '/service', '/blog', '/visits'] as const) {
    const root = normPath(withBase(section));
    if (target === root) {
      return current === root || current.startsWith(`${root}/`);
    }
  }

  return current === target;
}

const homeHref = withBase('/');
---

<header class="sticky top-0 z-40 w-full border-b border-secondary/35 bg-secondary">
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-page/30" aria-hidden="true" />
  <div
    class="relative flex w-full flex-wrap items-center justify-between gap-4 px-5 py-4 sm:px-8 md:px-12 lg:px-16 xl:px-20 2xl:px-24"
  >
    <p class="font-serif text-xl font-semibold tracking-tight text-ink">
      <a
        href={homeHref}
        class="text-white no-underline transition-colors hover:text-page"
      >
        April Jiawei Zhang 張家維
      </a>
    </p>
    <nav
      aria-label="Primary"
      class="flex flex-wrap gap-x-1 gap-y-2 text-sm font-medium sm:text-base"
    >
      {
        navItems.map(({ href, label }) => (
          label === 'Blog' ? (
            <span class="relative inline-flex align-middle group">
              <a
                href={href}
                aria-current={isActive(href) ? 'page' : undefined}
                class:list={[
                  'inline-flex items-center rounded-full px-3 py-1.5 no-underline transition-all',
                  isActive(href)
                    ? 'bg-page/20 text-white shadow-sm ring-2 ring-page/40'
                    : 'text-white/90 hover:bg-page/15 hover:text-white',
                ]}
              >
                {label}
              </a>

              <button
                type="button"
                data-blog-admin-trigger
                class="pointer-events-none absolute -bottom-7 left-1/2 hidden -translate-x-1/2 rounded-full border border-page/40 bg-secondary px-3 py-1 text-xs font-semibold text-white shadow-sm opacity-0 transition-all group-hover:pointer-events-auto group-hover:flex group-hover:opacity-100"
              >
                Admin
              </button>
            </span>
          ) : (
            <a
              href={href}
              aria-current={isActive(href) ? 'page' : undefined}
              class:list={[
                'inline-flex items-center rounded-full px-3 py-1.5 no-underline transition-all',
                isActive(href)
                  ? 'bg-page/20 text-white shadow-sm ring-2 ring-page/40'
                  : 'text-white/90 hover:bg-page/15 hover:text-white',
              ]}
            >
              {label}
            </a>
          )
        ))
      }
    </nav>
  </div>
</header>

<dialog
  id="blog-admin-dialog"
  class="fixed left-1/2 top-1/2 m-0 -translate-x-1/2 -translate-y-1/2 rounded-xl border border-border bg-surface p-0 text-ink shadow-xl backdrop:bg-ink/30"
>
  <form id="blog-admin-form" method="dialog" class="w-[min(92vw,28rem)] p-5">
    <div class="flex items-center justify-between gap-3">
      <p class="font-serif text-xl font-semibold text-ink">Admin</p>
      <button class="rounded-full border border-border bg-page px-3 py-1 text-sm font-semibold text-ink hover:bg-neutral-hover" value="cancel">
        Close
      </button>
    </div>
    <p class="mt-2 text-sm text-muted">Enter the password to enable blog editing on this device.</p>

    <input
      id="blog-admin-password"
      type="password"
      class="mt-4 w-full rounded-md border border-border bg-page px-3 py-2 text-sm"
      placeholder="Password"
      autocomplete="current-password"
    />

    <p id="blog-admin-msg" class="mt-3 text-sm text-muted"></p>

    <div class="mt-5 flex items-center justify-end gap-2">
      <button
        type="submit"
        id="blog-admin-confirm"
        class="rounded-full bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-secondary hover:text-ink"
      >
        Continue
      </button>
    </div>
  </form>
</dialog>

<script>
  (() => {
    const triggers = Array.from(document.querySelectorAll("[data-blog-admin-trigger]"));
    const dlg = document.getElementById("blog-admin-dialog");
    if (!(dlg instanceof HTMLDialogElement)) return;
    const input = document.getElementById("blog-admin-password");
    const msg = document.getElementById("blog-admin-msg");
    const confirm = document.getElementById("blog-admin-confirm");
    const form = document.getElementById("blog-admin-form");
    const password = "199044";

    function open() {
      try {
        input && (input.value = "");
        msg && (msg.textContent = "");
      } catch {}
      dlg.showModal();
      setTimeout(() => input && input.focus(), 0);
    }

    triggers.forEach((t) => t.addEventListener("click", (e) => {
      e.preventDefault();
      open();
    }));

    function submit() {
      const v = (input && input.value ? String(input.value) : "").trim();
      if (v !== password) {
        if (msg) msg.textContent = "Incorrect password.";
        return false;
      }
      try {
        window.sessionStorage.setItem("BLOG_ADMIN_KEY", password);
      } catch {}
      dlg.close();
      // After unlocking, stay on /blog in "admin mode" (edit buttons appear there).
      window.location.href = "/blog/";
      return true;
    }

    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      submit();
    });

    confirm?.addEventListener("click", (e) => {
      e.preventDefault();
      submit();
    });
  })();
</script>
