---
import { navItems } from '../data/nav';
import { withBase } from '../utils/paths';

function normPath(pathname: string): string {
  const x = pathname.replace(/\/$/, '') || '/';
  return x;
}

const current = normPath(Astro.url.pathname);

function isActive(href: string): boolean {
  const target = normPath(new URL(href, Astro.url).pathname);
  if (target === '/') return current === '/';

  for (const section of ['/research', '/teaching', '/service', '/blog', '/visits'] as const) {
    const root = normPath(withBase(section));
    if (target === root) {
      return current === root || current.startsWith(`${root}/`);
    }
  }

  return current === target;
}

const homeHref = withBase('/');
---

<header class="sticky top-0 z-40 w-full border-b border-secondary/20 bg-page/92 backdrop-blur-sm">
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-secondary/35" aria-hidden="true" />
  <div
    class="relative flex w-full flex-wrap items-center justify-between gap-4 px-5 py-4 sm:px-8 md:px-12 lg:px-16 xl:px-20 2xl:px-24"
  >
    <p class="font-serif text-xl font-semibold tracking-tight text-ink">
      <a
        href={homeHref}
        class="text-ink no-underline transition-colors hover:text-secondary"
      >
        April Jiawei Zhang
      </a>
    </p>
    <nav
      aria-label="Primary"
      class="flex flex-wrap gap-x-1 gap-y-2 text-sm font-medium sm:text-base"
    >
      {
        navItems.map(({ href, label }) => (
          <a
            href={href}
            aria-current={isActive(href) ? 'page' : undefined}
            class:list={[
              'rounded-full px-3 py-1.5 no-underline transition-all',
              isActive(href)
                ? 'bg-secondary text-white shadow-sm ring-2 ring-secondary/30'
                : 'text-muted hover:bg-secondary/12 hover:text-ink',
            ]}
          >
            {label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
