---
import { researchThemesDetailed } from '../data/cv';

const borderRotate = ['border-l-primary', 'border-l-secondary', 'border-l-accent-purple'] as const;
---

<div class="space-y-10">
  {
    researchThemesDetailed.map((theme, i) => (
      <section id={theme.id} class="scroll-mt-24">
        <h2
          class:list={[
            'font-serif text-2xl font-semibold text-ink sm:text-3xl',
            'border-l-4 pl-4',
            borderRotate[i % 3],
          ]}
        >
          {theme.title}
        </h2>
        <p class="mt-3 max-w-3xl text-pretty text-base leading-relaxed text-muted sm:text-lg">{theme.description}</p>
        {theme.upcoming.length > 0 ? (
          <div class="mt-5">
            <h3 class="text-xs font-bold uppercase tracking-wider text-secondary">Upcoming manuscripts</h3>
            <ul class="mt-3 space-y-4">
              {theme.upcoming.map((u) => (
                <li class="border-l-2 border-secondary/50 pl-4">
                  <p class="text-xs font-semibold uppercase tracking-wide text-muted">{u.status}</p>
                  <p
                    class="mt-1 text-pretty text-base leading-relaxed text-ink/95 [&_em]:font-serif [&_em]:italic [&_em]:text-primary"
                    set:html={u.citationHtml}
                  />
                </li>
              ))}
            </ul>
          </div>
        ) : null}
      </section>
    ))
  }
</div>
