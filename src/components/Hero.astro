---
import { person, siteTagline, summaryHtml } from '../data/cv';
import { contact } from '../data/contact';
import ProfileLinks from './ProfileLinks.astro';

const profileSrc = `${import.meta.env.BASE_URL.replace(/\/?$/, '/')}images/profile.jpg`;
---

<section
  class="relative w-full border-b-2 border-primary bg-page"
  aria-labelledby="hero-heading"
>
  <div
    class="relative grid w-full gap-8 px-5 py-10 sm:px-8 md:px-12 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center lg:gap-12 lg:px-16 lg:py-12 xl:px-20 2xl:px-24"
  >
    <div class="min-w-0">
      <h1
        id="hero-heading"
        class="mt-3 font-serif text-4xl font-semibold tracking-tight text-ink sm:text-5xl lg:text-[2.75rem] lg:leading-tight"
      >
        {person.fullDisplayName}
      </h1>
      <p class="mt-2 font-serif text-xl text-secondary sm:text-2xl">{siteTagline}</p>
      <div
        class="mt-5 max-w-3xl text-pretty text-base leading-relaxed text-ink/95 sm:text-lg lg:max-w-none lg:text-xl lg:leading-relaxed"
        set:html={summaryHtml}
      />

      <div
        id="contact"
        class="mt-8 w-full scroll-mt-24 rounded-xl border border-border bg-surface p-4 sm:p-5"
      >
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-start">
          <div class="min-w-0">
            <p class="text-xs font-bold uppercase tracking-wider text-primary">Contact</p>
            <div class="mt-4 grid gap-3 sm:grid-cols-3 sm:[grid-auto-rows:1fr]">
              <a
                class="group flex h-full items-start gap-3 rounded-xl border border-border bg-page p-3 no-underline transition-colors hover:bg-neutral-hover"
                href={`mailto:${contact.cityu}`}
              >
                <span class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-border bg-surface text-primary">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                  </svg>
                </span>
                <span class="min-w-0">
                  <span class="block min-h-[2.5rem] text-xs font-bold uppercase leading-snug tracking-wider text-muted">
                    Professional &amp; work issues
                  </span>
                  <span class="mt-1 block truncate text-sm font-semibold text-primary group-hover:text-ink" title={contact.cityu}>
                    {contact.cityu}
                  </span>
                </span>
              </a>

              <a
                class="group flex h-full items-start gap-3 rounded-xl border border-border bg-page p-3 no-underline transition-colors hover:bg-neutral-hover"
                href={`mailto:${contact.gmail}`}
              >
                <span class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-border bg-surface text-primary">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                  </svg>
                </span>
                <span class="min-w-0">
                  <span class="block min-h-[2.5rem] text-xs font-bold uppercase leading-snug tracking-wider text-muted">
                    Academic &amp; personal (international)
                  </span>
                  <span class="mt-1 block truncate text-sm font-semibold text-primary group-hover:text-ink" title={contact.gmail}>
                    {contact.gmail}
                  </span>
                </span>
              </a>

              <a
                class="group flex h-full items-start gap-3 rounded-xl border border-border bg-page p-3 no-underline transition-colors hover:bg-neutral-hover"
                href={`mailto:${contact.outlook}`}
              >
                <span class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-border bg-surface text-primary">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                  </svg>
                </span>
                <span class="min-w-0">
                  <span class="block min-h-[2.5rem] text-xs font-bold uppercase leading-snug tracking-wider text-muted">
                    Academic &amp; personal (mainland China)
                  </span>
                  <span class="mt-1 block truncate text-sm font-semibold text-primary group-hover:text-ink" title={contact.outlook}>
                    {contact.outlook}
                  </span>
                </span>
              </a>
            </div>
          </div>

          <div class="min-w-0 lg:pt-6">
            <p class="text-xs font-bold uppercase tracking-wider text-primary">Academic IDs</p>
            <div class="mt-3">
              <ProfileLinks layout="horizontal" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mx-auto w-56 shrink-0 sm:w-64 lg:mx-0 lg:w-72 xl:w-80">
      <div class="overflow-hidden rounded-xl border border-border bg-surface shadow-sm">
        <img
          src={profileSrc}
          alt="April Jiawei Zhang 張家維"
          width="640"
          height="800"
          class="h-auto w-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>
