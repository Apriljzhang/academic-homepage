---
import { person, siteTagline, summary } from '../data/cv';
import { contact } from '../data/contact';
import ProfileLinks from './ProfileLinks.astro';

const profileSrc = `${import.meta.env.BASE_URL.replace(/\/?$/, '/')}images/profile.jpg`;
---

<section
  class="relative w-full border-b-2 border-primary bg-gradient-to-b from-secondary/[0.12] via-page to-page"
  aria-labelledby="hero-heading"
>
  <div
    class="relative grid w-full gap-8 px-5 py-10 sm:px-8 md:px-12 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center lg:gap-12 lg:px-16 lg:py-12 xl:px-20 2xl:px-24"
  >
    <div class="min-w-0">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Faculty profile</p>
      <h1
        id="hero-heading"
        class="mt-3 font-serif text-4xl font-semibold tracking-tight text-ink sm:text-5xl lg:text-[2.75rem] lg:leading-tight"
      >
        {person.fullDisplayName}
      </h1>
      <p class="mt-2 font-serif text-xl text-secondary sm:text-2xl">{siteTagline}</p>
      <p class="mt-4 text-lg text-muted lg:text-xl">
        {person.title}, {person.affiliation}
      </p>
      <p class="mt-5 max-w-3xl text-pretty text-base leading-relaxed text-ink/95 sm:text-lg lg:text-xl lg:leading-relaxed">
        {summary}
      </p>

      <div
        id="contact"
        class="mt-8 flex max-w-4xl scroll-mt-24 flex-col gap-5 rounded-xl border border-border bg-surface p-4 sm:flex-row sm:items-start sm:gap-8 sm:p-5"
      >
        <div class="min-w-0 flex-1 space-y-2">
          <p class="text-xs font-bold uppercase tracking-wider text-primary">Contact</p>
          <p class="text-sm text-muted">Work</p>
          <p>
            <a
              class="text-base font-semibold text-primary no-underline decoration-primary/40 underline-offset-2 hover:text-primary hover:underline hover:decoration-primary"
              href={`mailto:${contact.cityu}`}>{contact.cityu}</a
            >
          </p>
          <p class="pt-1 text-sm text-muted">Personal</p>
          <p>
            <a
              class="text-sm font-medium text-ink no-underline decoration-border/60 underline-offset-2 hover:text-ink hover:underline hover:decoration-border"
              href={`mailto:${contact.gmail}`}>{contact.gmail}</a
            >
          </p>
          <p>
            <a
              class="text-sm font-medium text-ink no-underline decoration-border/60 underline-offset-2 hover:text-ink hover:underline hover:decoration-border"
              href={`mailto:${contact.outlook}`}>{contact.outlook}</a
            >
          </p>
          <p class="text-sm text-muted">
            Office:
            <a
              class="ml-1 font-medium text-ink no-underline decoration-border/60 underline-offset-2 hover:text-ink hover:underline hover:decoration-border"
              href="tel:+85385902644">{person.officePhone}</a
            >
          </p>
        </div>
        <ProfileLinks layout="vertical" />
      </div>
    </div>

    <div class="mx-auto w-56 shrink-0 sm:w-64 lg:mx-0 lg:w-72 xl:w-80">
      <div class="overflow-hidden rounded-xl border border-border bg-surface shadow-sm">
        <img
          src={profileSrc}
          alt="April Jiawei Zhang 張家維"
          width="640"
          height="800"
          class="h-auto w-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>
