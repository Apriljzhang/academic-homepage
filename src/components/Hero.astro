---
import { person, siteTagline, summaryHtml } from '../data/cv';
import { contact } from '../data/contact';
import { academicIds } from '../data/profiles';

const profileSrc = `${import.meta.env.BASE_URL.replace(/\/?$/, '/')}images/profile.jpg`;
---

<section
  class="relative w-full border-b-2 border-primary bg-page"
  aria-labelledby="hero-heading"
>
  <div
    class="relative grid w-full gap-8 px-5 py-10 sm:px-8 md:px-12 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center lg:gap-12 lg:px-16 lg:py-12 xl:px-20 2xl:px-24"
  >
    <div class="min-w-0">
      <h1
        id="hero-heading"
        class="mt-3 font-serif text-4xl font-semibold tracking-tight text-ink sm:text-5xl lg:text-[2.75rem] lg:leading-tight"
      >
        {person.fullDisplayName}
      </h1>
      <p class="mt-2 font-serif text-xl text-secondary sm:text-2xl">{siteTagline}</p>
      <div
        class="mt-5 max-w-3xl text-pretty text-base leading-relaxed text-ink/95 sm:text-lg lg:max-w-none lg:text-xl lg:leading-relaxed"
        set:html={summaryHtml}
      />

      <div
        id="contact"
        class="mt-8 w-full scroll-mt-24 rounded-xl border border-border bg-surface p-4 sm:p-5"
      >
        <p class="text-xs font-bold uppercase tracking-wider text-primary">Contact</p>
        <div class="mt-3 flex flex-wrap items-center gap-2">
          <a
            class="inline-flex items-center justify-center gap-1.5 rounded-full border border-border bg-page px-3 py-1 text-xs font-semibold leading-tight text-primary no-underline transition-colors hover:bg-neutral-hover hover:text-ink sm:text-sm"
            href={`mailto:${contact.cityu}`}
            title={contact.cityu}
          >
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
            <span>Professional &amp; Work (CityU)</span>
          </a>
          <div class="flex flex-row flex-wrap items-center gap-2 sm:flex-nowrap">
            <a
              class="inline-flex items-center justify-center gap-1.5 rounded-full border border-border bg-page px-3 py-1 text-xs font-semibold leading-tight text-primary no-underline transition-colors hover:bg-neutral-hover hover:text-ink sm:text-sm"
              href={`mailto:${contact.gmail}`}
              title={contact.gmail}
            >
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
              <span>Academic &amp; Personal (International)</span>
            </a>
            <a
              class="inline-flex items-center justify-center gap-1.5 rounded-full border border-border bg-page px-3 py-1 text-xs font-semibold leading-tight text-primary no-underline transition-colors hover:bg-neutral-hover hover:text-ink sm:text-sm"
              href={`mailto:${contact.outlook}`}
              title={contact.outlook}
            >
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
              <span>Academic &amp; Personal (Mainland China)</span>
            </a>
          </div>
          <a href={academicIds.cityuProfile.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full border border-border bg-page px-3 py-1 text-xs font-semibold leading-tight text-primary no-underline transition-colors hover:bg-neutral-hover hover:text-ink sm:text-sm">CityU Macau</a>
          <a href={academicIds.googleScholar.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full border border-border bg-page px-3 py-1 text-xs font-semibold leading-tight text-primary no-underline transition-colors hover:bg-neutral-hover hover:text-ink sm:text-sm">Google Scholar</a>
          <a href={academicIds.researchGate.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full border border-border bg-page px-3 py-1 text-xs font-semibold leading-tight text-primary no-underline transition-colors hover:bg-neutral-hover hover:text-ink sm:text-sm">ResearchGate</a>
          <a href="https://www.linkedin.com/in/april-jiawei-zhang-485813110/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full border border-border bg-page px-3 py-1 text-xs font-semibold leading-tight text-primary no-underline transition-colors hover:bg-neutral-hover hover:text-ink sm:text-sm">LinkedIn</a>
          <a href="https://github.com/Apriljzhang" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full border border-border bg-page px-3 py-1 text-xs font-semibold leading-tight text-primary no-underline transition-colors hover:bg-neutral-hover hover:text-ink sm:text-sm">GitHub</a>
          <a href={academicIds.orcid.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full border border-border bg-page px-3 py-1 text-xs font-semibold leading-tight text-primary no-underline transition-colors hover:bg-neutral-hover hover:text-ink sm:text-sm">ORCID</a>
          <a href={academicIds.webOfScience.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full border border-border bg-page px-3 py-1 text-xs font-semibold leading-tight text-primary no-underline transition-colors hover:bg-neutral-hover hover:text-ink sm:text-sm">WoS</a>
          <a href={academicIds.scopus.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full border border-border bg-page px-3 py-1 text-xs font-semibold leading-tight text-primary no-underline transition-colors hover:bg-neutral-hover hover:text-ink sm:text-sm">Scopus</a>
        </div>
      </div>
    </div>

    <div class="mx-auto w-56 shrink-0 sm:w-64 lg:mx-0 lg:w-72 xl:w-80">
      <div class="overflow-hidden rounded-xl border border-border bg-surface shadow-sm">
        <img
          src={profileSrc}
          alt="April Jiawei Zhang 張家維"
          width="640"
          height="800"
          class="h-auto w-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>
