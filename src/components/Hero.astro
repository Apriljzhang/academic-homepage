---
import { person } from '../data/cv';
import { contact } from '../data/contact';
import ProfileLinks from './ProfileLinks.astro';

const profileSrc = `${import.meta.env.BASE_URL.replace(/\/?$/, '/')}images/profile.jpg`;
---

<section
  class="relative overflow-hidden border-b border-border/60 bg-gradient-to-b from-primary-faint/90 via-page to-page"
  aria-labelledby="hero-heading"
>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-r from-accent-yellow/25 via-transparent to-accent-pink/20"
    aria-hidden="true"
  />
  <div class="mx-auto grid max-w-3xl gap-8 px-4 py-12 sm:grid-cols-[minmax(0,1fr)_160px] sm:items-start sm:px-6 sm:py-16">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-primary">Faculty profile</p>
      <h1 id="hero-heading" class="mt-2 font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
        {person.fullDisplayName}
      </h1>
      <p class="mt-3 text-lg text-muted">
        {person.title}, {person.affiliation}
      </p>
      <p class="mt-4 max-w-prose text-pretty leading-relaxed text-ink/95">
        Research in language education, formative assessment, motivation, and language testing—with a growing interest in
        generative AI and multilingual higher education in Macau.
      </p>

      <div
        id="contact"
        class="mt-8 space-y-4 scroll-mt-24 rounded-xl border border-border/70 bg-surface/80 p-5 shadow-sm"
      >
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-muted">Contact</p>
          <p class="mt-1">
            <span class="text-sm text-muted">CityU (primary)</span><br />
            <a class="text-base font-medium" href={`mailto:${contact.cityu}`}>{contact.cityu}</a>
          </p>
          <p class="mt-3 text-sm text-muted">
            Personal (Gmail):
            <a class="ml-1 font-medium" href={`mailto:${contact.gmail}`}>{contact.gmail}</a>
          </p>
          <p class="mt-1 text-sm text-muted">
            Outlook:
            <a class="ml-1 font-medium" href={`mailto:${contact.outlook}`}>{contact.outlook}</a>
          </p>
          <p class="mt-2 text-sm text-muted">
            Office:
            <a class="ml-1" href="tel:+85385902644">{person.officePhone}</a>
          </p>
        </div>
        <ProfileLinks />
      </div>
    </div>

    <div class="mx-auto w-36 shrink-0 sm:mx-0 sm:w-40">
      <div
        class="overflow-hidden rounded-2xl border-2 border-accent-yellow/60 bg-surface shadow-md ring-1 ring-border/40"
      >
        <img
          src={profileSrc}
          alt="April Jiawei Zhang 張家維"
          width="320"
          height="400"
          class="h-auto w-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>
