---
import { person, siteTagline, summary } from '../data/cv';
import { contact } from '../data/contact';
import ProfileLinks from './ProfileLinks.astro';

const profileSrc = `${import.meta.env.BASE_URL.replace(/\/?$/, '/')}images/profile.jpg`;
---

<section
  class="relative w-full overflow-hidden border-b border-border/50"
  aria-labelledby="hero-heading"
>
  <div class="absolute inset-0 bg-page" aria-hidden="true" />
  <div
    class="pointer-events-none absolute right-0 top-0 h-48 w-64 rounded-bl-3xl bg-secondary/15"
    aria-hidden="true"
  />
  <div
    class="pointer-events-none absolute bottom-0 left-0 h-40 w-56 rounded-tr-3xl bg-primary/15"
    aria-hidden="true"
  />
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-primary/70"
    aria-hidden="true"
  />

  <div
    class="relative grid w-full gap-10 px-5 py-14 sm:px-8 md:px-12 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center lg:gap-16 lg:px-16 lg:py-20 xl:px-20 2xl:px-24"
  >
    <div class="min-w-0">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Faculty profile</p>
      <h1
        id="hero-heading"
        class="mt-3 font-serif text-4xl font-semibold tracking-tight text-ink sm:text-5xl lg:text-[2.75rem] lg:leading-tight"
      >
        {person.fullDisplayName}
      </h1>
      <p class="mt-2 font-serif text-xl text-secondary sm:text-2xl">{siteTagline}</p>
      <p class="mt-4 text-lg text-muted lg:text-xl">
        {person.title}, {person.affiliation}
      </p>
      <p class="mt-6 max-w-3xl text-pretty text-lg leading-relaxed text-ink/95 lg:text-xl lg:leading-relaxed">
        {summary}
      </p>

      <div
        id="contact"
        class="mt-10 max-w-2xl space-y-5 scroll-mt-24 rounded-2xl border border-border/80 bg-surface/95 p-6 shadow-sm lg:p-7"
      >
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-primary">Contact</p>
          <p class="mt-2 text-sm text-muted">Work</p>
          <p>
            <a class="text-base font-semibold text-ink no-underline hover:text-primary" href={`mailto:${contact.cityu}`}
              >{contact.cityu}</a
            >
          </p>
          <p class="mt-4 text-sm text-muted">Personal</p>
          <p class="mt-1">
            <a class="font-medium text-primary no-underline hover:underline" href={`mailto:${contact.gmail}`}
              >{contact.gmail}</a
            >
          </p>
          <p class="mt-1">
            <a class="font-medium text-primary no-underline hover:underline" href={`mailto:${contact.outlook}`}
              >{contact.outlook}</a
            >
          </p>
          <p class="mt-3 text-sm text-muted">
            Office:
            <a class="ml-1 font-medium text-primary no-underline hover:underline" href="tel:+85385902644"
              >{person.officePhone}</a
            >
          </p>
        </div>
        <ProfileLinks />
      </div>
    </div>

    <div class="mx-auto w-56 shrink-0 sm:w-64 lg:mx-0 lg:w-72 xl:w-80">
      <div class="overflow-hidden rounded-2xl border border-border/60 bg-surface shadow-md">
        <img
          src={profileSrc}
          alt="April Jiawei Zhang 張家維"
          width="640"
          height="800"
          class="h-auto w-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>
