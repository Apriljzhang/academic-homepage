---
import { academicIds } from '../data/profiles';

const links = [
  academicIds.googleScholar,
  academicIds.orcid,
  academicIds.scopus,
  academicIds.webOfScience,
] as const;
---

<ul class="flex flex-wrap gap-2">
  {
    links.map(({ label, href }, i) => (
      <li>
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            'inline-flex items-center rounded-full border px-3 py-1.5 text-sm font-semibold no-underline transition-colors',
            i === 0
              ? 'border-primary/35 bg-primary-faint text-primary hover:bg-secondary-faint hover:text-secondary'
              : 'border-border/80 bg-page text-primary hover:bg-accent-purple-faint hover:text-accent-purple',
          ]}
        >
          {label}
        </a>
      </li>
    ))
  }
</ul>
