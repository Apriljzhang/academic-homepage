---
import { academicProfileLinks } from '../data/profiles';

interface Props {
  layout?: 'horizontal' | 'vertical';
}

const { layout = 'horizontal' } = Astro.props;

const listClass =
  layout === 'vertical'
    ? 'flex flex-col gap-2 sm:shrink-0 sm:items-end sm:text-right'
    : 'flex flex-wrap gap-x-5 gap-y-2';

const linkClass =
  'text-sm font-semibold text-primary no-underline decoration-primary/40 underline-offset-2 hover:underline hover:decoration-primary';
---

<ul class={listClass}>
  {
    academicProfileLinks.map(({ label, href }) => (
      <li class:list={[layout === 'vertical' && 'w-full sm:w-auto']}>
        <a href={href} target="_blank" rel="noopener noreferrer" class:list={[linkClass, layout === 'vertical' && 'block']}>
          {label}
        </a>
      </li>
    ))
  }
</ul>
