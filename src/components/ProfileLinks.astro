---
import { academicIds } from '../data/profiles';

const links = [
  academicIds.googleScholar,
  academicIds.orcid,
  academicIds.scopus,
  academicIds.webOfScience,
] as const;
---

<div>
  <p class="text-xs font-bold uppercase tracking-wider text-primary">Academic IDs</p>
  <p class="mt-1 text-xs text-muted">
    Google Scholar, ORCID, Scopus, and Web of Science.
  </p>
  <ul class="mt-3 flex flex-wrap gap-2">
    {
      links.map(({ label, href }, i) => (
        <li>
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              'inline-flex items-center rounded-full border px-3 py-1.5 text-sm font-semibold no-underline transition-all',
              i === 0
                ? 'border-primary/40 bg-primary-faint text-primary hover:border-secondary hover:bg-secondary-faint hover:text-secondary'
                : 'border-border bg-surface text-primary hover:border-accent-pink hover:bg-blush-faint',
            ]}
          >
            {label}
          </a>
        </li>
      ))
    }
  </ul>
</div>
