---
import { academicProfileLinks } from '../data/profiles';

interface Props {
  layout?: 'horizontal' | 'vertical';
}

const { layout = 'horizontal' } = Astro.props;

const listClass = layout === 'vertical' ? 'flex flex-col gap-2 sm:shrink-0 sm:w-44 lg:w-48' : 'flex flex-wrap gap-2';
---

<ul class={listClass}>
  {
    academicProfileLinks.map(({ label, href }) => (
      <li class:list={[layout === 'vertical' && 'w-full']}>
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            'inline-flex items-center rounded-full border border-border/80 bg-page px-3 py-1.5 text-sm font-semibold text-primary no-underline transition-colors hover:bg-accent-purple-faint hover:text-accent-purple',
            layout === 'vertical' ? 'w-full justify-center sm:justify-start' : '',
          ]}
        >
          {label}
        </a>
      </li>
    ))
  }
</ul>
