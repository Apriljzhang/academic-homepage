---
import { researcherProfiles } from '../data/profiles';

const links = [
  researcherProfiles.orcid,
  researcherProfiles.scopus,
  researcherProfiles.webOfScience,
] as const;
---

<p class="text-sm font-medium text-muted">Research profiles</p>
<ul class="mt-2 flex flex-wrap gap-2">
  {
    links.map(({ label, href }) => (
      <li>
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full border border-border bg-primary-faint/80 px-3 py-1 text-sm font-medium text-primary no-underline hover:border-accent-pink hover:bg-accent-pink/50"
        >
          {label}
        </a>
      </li>
    ))
  }
</ul>
