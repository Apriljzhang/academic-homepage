---
import { homeSectionCards } from '../data/cv';
import { withBase } from '../utils/paths';

const accentStyles = {
  green: {
    bar: 'bg-primary',
    kicker: 'text-primary',
    panel: 'bg-primary-faint',
    hoverBorder: 'hover:border-primary/35',
    hoverRing: 'group-hover:ring-primary/20',
  },
  blue: {
    bar: 'bg-secondary',
    kicker: 'text-secondary',
    panel: 'bg-secondary-faint',
    hoverBorder: 'hover:border-secondary/35',
    hoverRing: 'group-hover:ring-secondary/20',
  },
  purple: {
    bar: 'bg-accent-purple',
    kicker: 'text-accent-purple',
    panel: 'bg-accent-purple-faint',
    hoverBorder: 'hover:border-accent-purple/35',
    hoverRing: 'group-hover:ring-accent-purple/20',
  },
} as const;
---

<section
  class="w-full border-t border-border/50 bg-page px-5 py-10 sm:px-8 md:px-12 lg:px-16 lg:py-14 xl:px-20 2xl:px-24"
  aria-labelledby="explore-heading"
>
  <h2 id="explore-heading" class="font-serif text-2xl font-semibold text-ink sm:text-3xl">Explore</h2>

  <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3 lg:gap-6">
    {
      homeSectionCards.map((card) => {
        const a = accentStyles[card.accent];
        return (
          <a
            href={withBase(`/${card.slug}`)}
            class:list={[
              'group relative flex min-h-[180px] flex-col overflow-hidden rounded-2xl border border-border/70 bg-surface p-5 shadow-sm ring-2 ring-transparent transition-all duration-200 sm:p-6',
              'hover:-translate-y-0.5 hover:shadow-md',
              a.panel,
              a.hoverBorder,
              a.hoverRing,
              'hover:ring-2',
            ]}
          >
            <div class:list={['h-1.5 w-14 shrink-0 rounded-full', a.bar]} aria-hidden="true" />
            <p class:list={['mt-5 text-xs font-bold uppercase tracking-[0.2em]', a.kicker]}>{card.kicker}</p>
            <h3 class="mt-2 font-serif text-2xl font-semibold text-ink group-hover:text-primary">
              {card.title}
            </h3>
            <p class="mt-3 flex-1 text-pretty leading-relaxed text-muted">{card.description}</p>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-primary group-hover:text-secondary">
              Open section
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </a>
        );
      })
    }
  </div>
</section>
