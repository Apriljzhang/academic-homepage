---
import { homeSectionCards } from '../data/cv';
import { withBase } from '../utils/paths';

const accentStyles = {
  green: {
    kicker: 'text-primary',
    left: 'border-l-4 border-primary',
    hoverRing: 'group-hover:ring-primary/35',
  },
  blue: {
    kicker: 'text-secondary',
    left: 'border-l-4 border-secondary',
    hoverRing: 'group-hover:ring-secondary/35',
  },
  purple: {
    kicker: 'text-accent-purple',
    left: 'border-l-4 border-accent-purple',
    hoverRing: 'group-hover:ring-accent-purple/50',
  },
} as const;
---

<section
  class="w-full border-t border-border bg-surface px-5 py-10 sm:px-8 md:px-12 lg:px-16 lg:py-12 xl:px-20 2xl:px-24"
  aria-labelledby="explore-heading"
>
  <h2 id="explore-heading" class="font-serif text-2xl font-semibold text-ink sm:text-3xl">Explore</h2>

  <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3 lg:gap-5">
    {
      homeSectionCards.map((card) => {
        const a = accentStyles[card.accent];
        return (
          <a
            href={withBase(`/${card.slug}`)}
            class:list={[
              'group relative flex min-h-[180px] flex-col overflow-hidden rounded-xl border border-border bg-surface p-5 shadow-sm ring-2 ring-transparent transition-all duration-200 sm:p-6',
              a.left,
              'hover:-translate-y-0.5 hover:shadow-md',
              a.hoverRing,
              'hover:ring-2',
            ]}
          >
            <p class:list={['text-xs font-bold uppercase tracking-[0.2em]', a.kicker]}>{card.kicker}</p>
            <h3 class="mt-2 font-serif text-2xl font-semibold text-ink group-hover:text-primary">
              {card.title}
            </h3>
            <p class="mt-3 flex-1 text-pretty text-sm leading-relaxed text-muted">{card.description}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary group-hover:text-secondary">
              Open section
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </a>
        );
      })
    }
  </div>
</section>
