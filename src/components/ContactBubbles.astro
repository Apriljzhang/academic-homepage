---
import { contact } from '../data/contact';
import { academicIds } from '../data/profiles';

interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

const bubbleClass =
  'inline-flex min-h-9 items-center justify-center rounded-full border border-border bg-page px-3 py-1.5 text-sm font-semibold text-primary no-underline transition-colors hover:bg-neutral-hover hover:text-ink';
---

<div class:list={['grid items-stretch gap-2 sm:grid-cols-2 lg:grid-cols-[minmax(0,1.22fr)_minmax(0,1.62fr)_minmax(0,0.66fr)_minmax(0,0.86fr)_minmax(0,0.66fr)_minmax(0,0.72fr)]', className]}>
  <a
    class={`${bubbleClass} gap-1.5 text-center text-xs sm:text-sm lg:row-span-2 lg:min-h-14`}
    href={`mailto:${contact.cityu}`}
    title={contact.cityu}
  >
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
      <polyline points="22,6 12,13 2,6" />
    </svg>
    <span class="inline-flex flex-col leading-tight">
      <span class="whitespace-nowrap">Professional (CityU Macau)</span>
      <span class="whitespace-nowrap">Primary institutional contact</span>
    </span>
  </a>

  <a
    class={`${bubbleClass} gap-1.5 text-center text-xs sm:text-sm`}
    href={`mailto:${contact.gmail}`}
    title={contact.gmail}
  >
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
      <polyline points="22,6 12,13 2,6" />
    </svg>
    <span class="inline-flex flex-col leading-tight">
      <span class="whitespace-nowrap">Academic and personal via Gmail</span>
      <span class="whitespace-nowrap">International access</span>
    </span>
  </a>

  <a href={academicIds.cityuProfile.href} target="_blank" rel="noopener noreferrer" class={bubbleClass}>
    CityU Macau
  </a>
  <a href={academicIds.researchGate.href} target="_blank" rel="noopener noreferrer" class={bubbleClass}>
    ResearchGate
  </a>
  <a href="https://github.com/Apriljzhang" target="_blank" rel="noopener noreferrer" class={bubbleClass}>
    GitHub
  </a>
  <a href={academicIds.webOfScience.href} target="_blank" rel="noopener noreferrer" class={bubbleClass}>
    Web of Science
  </a>

  <a
    class={`${bubbleClass} gap-1.5 text-center text-xs sm:text-sm lg:col-start-2`}
    href={`mailto:${contact.outlook}`}
    title={contact.outlook}
  >
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
      <polyline points="22,6 12,13 2,6" />
    </svg>
    <span class="inline-flex flex-col leading-tight">
      <span class="whitespace-nowrap">Academic and personal via Outlook</span>
      <span class="whitespace-nowrap">Mainland China access</span>
    </span>
  </a>
  <a href={academicIds.googleScholar.href} target="_blank" rel="noopener noreferrer" class={bubbleClass}>
    Google Scholar
  </a>
  <a href="https://www.linkedin.com/in/april-jiawei-zhang-485813110/" target="_blank" rel="noopener noreferrer" class={bubbleClass}>
    LinkedIn
  </a>
  <a href={academicIds.orcid.href} target="_blank" rel="noopener noreferrer" class={bubbleClass}>
    ORCID
  </a>
  <a href={academicIds.scopus.href} target="_blank" rel="noopener noreferrer" class={bubbleClass}>
    Scopus
  </a>
</div>
