---
import { talks } from '../data/cv';
---

<ul class="mt-6 space-y-4">
  {
    talks.map((t) => (
      <li class="border-l-2 border-primary/40 pl-4">
        {t.paperTitle ? (
          <p class="text-base font-medium leading-snug text-ink">{t.paperTitle}</p>
        ) : null}
        <p class:list={[t.paperTitle ? 'mt-1 text-sm text-muted' : 'text-base font-medium text-ink']}>
          {t.event}
        </p>
        <p class="mt-0.5 text-sm text-muted">
          {t.place} · {t.date}
        </p>
      </li>
    ))
  }
</ul>
