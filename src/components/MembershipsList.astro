---
import { professionalMemberships } from '../data/cv';
---

<section id="memberships" class="scroll-mt-24">
  <h2 class="font-serif text-2xl font-semibold text-ink">Professional memberships</h2>
  <ul class="mt-4 flex flex-wrap gap-2">
    {
      professionalMemberships.map((m) => (
        <li>
          {m.href ? (
            <a
              href={m.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex rounded-full border border-border bg-surface px-3 py-1.5 text-sm font-medium text-ink no-underline hover:border-secondary hover:bg-secondary-faint"
            >
              {m.name}
            </a>
          ) : (
            <span class="inline-flex rounded-full border border-border bg-surface px-3 py-1.5 text-sm font-medium text-ink">
              {m.name}
            </span>
          )}
        </li>
      ))
    }
  </ul>
</section>
