---
interface Props {
  as?: 'div' | 'li' | 'a';
  href?: string;
  class?: string;
  padding?: 'sm' | 'md' | 'lg';
  hoverLift?: boolean;
}

const { as = 'div', href, class: className, padding = 'md', hoverLift = false } = Astro.props;

const base =
  'rounded-xl border border-border bg-surface shadow-sm text-ink';

const pad =
  padding === 'sm' ? 'p-4' : padding === 'lg' ? 'p-6' : 'p-5';

const hover = hoverLift ? 'transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md' : '';
---

{as === 'a' ? (
  <a href={href} class:list={[base, pad, hover, className]}>
    <slot />
  </a>
) : as === 'li' ? (
  <li class:list={[base, pad, hover, className]}>
    <slot />
  </li>
) : (
  <div class:list={[base, pad, hover, className]}>
    <slot />
  </div>
)}

