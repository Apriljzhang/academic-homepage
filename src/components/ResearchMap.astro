---
import { researchFramework } from '../data/cv';

const quadrants = [
  {
    key: 'why',
    label: 'Why',
    sub: 'Motives',
    body: researchFramework.why,
    bar: 'bg-primary',
  },
  {
    key: 'who',
    label: 'Who',
    sub: 'Participants & contexts',
    body: researchFramework.who,
    bar: 'bg-secondary',
  },
  {
    key: 'what',
    label: 'What',
    sub: 'Research interests',
    body: researchFramework.what,
    bar: 'bg-accent-purple',
  },
  {
    key: 'how',
    label: 'How',
    sub: 'Methodology',
    body: researchFramework.how,
    bar: 'bg-primary',
  },
] as const;
---

<div class="mt-8">
  <h2 class="font-serif text-xl font-semibold text-ink sm:text-2xl">Research framework</h2>
  <p class="mt-2 max-w-3xl text-sm leading-relaxed text-muted sm:text-base">
    A simple map of what drives the work, who it involves, the substantive themes, and how enquiries are typically
    designed.
  </p>

  <div
    class="mt-5 grid gap-3 sm:grid-cols-2 lg:gap-4"
    role="img"
    aria-label="Research framework: why, who, what, how"
  >
    {
      quadrants.map((q) => (
        <div class="flex min-h-0 flex-col rounded-xl border border-border/70 bg-surface p-4 shadow-sm sm:p-5">
          <div class:list={['h-1 w-12 shrink-0 rounded-full', q.bar]} aria-hidden="true" />
          <p class="mt-3 font-serif text-lg font-semibold text-ink">
            {q.label}
            <span class="block text-xs font-sans font-normal uppercase tracking-wider text-muted">{q.sub}</span>
          </p>
          <p class="mt-2 text-pretty text-sm leading-relaxed text-ink/90 sm:text-base">{q.body}</p>
        </div>
      ))
    }
  </div>
</div>
