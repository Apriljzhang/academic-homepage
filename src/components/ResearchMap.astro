---
import { researchFramework } from '../data/cv';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const quadrants = [
  {
    key: 'why',
    label: 'Why',
    sub: 'Motives',
    body: researchFramework.why,
    borderLeft: 'border-l-4 border-primary',
  },
  {
    key: 'who',
    label: 'Who',
    sub: 'Participants & contexts',
    body: researchFramework.who,
    borderLeft: 'border-l-4 border-secondary',
  },
  {
    key: 'what',
    label: 'What',
    sub: 'Research interests',
    body: researchFramework.what,
    borderLeft: 'border-l-4 border-accent-purple',
  },
  {
    key: 'how',
    label: 'How',
    sub: 'Methodology',
    body: researchFramework.how,
    borderLeft: 'border-l-4 border-ink/55',
  },
] as const;
---

<div class:list={[className ?? 'mt-6']}>
  <h2 class="font-serif text-xl font-semibold text-ink sm:text-2xl">Research framework</h2>

  <div
    class="mt-4 grid grid-cols-1 gap-4 lg:gap-5"
    role="img"
    aria-label="Research framework: why, who, what, how"
  >
    {
      quadrants.map((q) => (
        <div
          class:list={['flex min-h-0 flex-col rounded-lg border border-border bg-surface p-5 sm:p-6', q.borderLeft]}
        >
          <p class="font-serif text-lg font-semibold text-ink">
            {q.label}
            <span class="block text-xs font-sans font-normal uppercase tracking-wider text-muted">{q.sub}</span>
          </p>
          <p class="mt-3 text-pretty text-base leading-relaxed text-ink/90">{q.body}</p>
        </div>
      ))
    }
  </div>
</div>
