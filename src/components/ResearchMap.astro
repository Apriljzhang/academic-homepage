---
import { researchFramework } from '../data/cv';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const quadrants = [
  {
    key: 'why',
    label: 'Why',
    sub: 'Motives',
    body: researchFramework.why,
  },
  {
    key: 'who',
    label: 'Who',
    sub: 'Participants & contexts',
    body: researchFramework.who,
  },
  {
    key: 'what',
    label: 'What',
    sub: 'Research interests',
    body: researchFramework.what,
  },
  {
    key: 'how',
    label: 'How',
    sub: 'Methodology',
    body: researchFramework.how,
  },
] as const;
---

<div class:list={[className ?? 'mt-6']}>
  <h2 class="font-serif text-xl font-semibold text-ink sm:text-2xl">Research framework</h2>

  <div
    class="mt-4 grid w-full grid-cols-1 gap-3 sm:gap-4"
    role="img"
    aria-label="Research framework: why, who, what, how"
  >
    {
      quadrants.map((q) => (
        <div
          class="flex min-h-0 w-full flex-col rounded-2xl border border-border/80 bg-page px-5 py-5 sm:rounded-3xl sm:px-6 sm:py-6"
        >
          <p class="font-serif text-lg font-semibold text-primary">
            {q.label}
            <span class="block text-xs font-sans font-normal uppercase tracking-wider text-muted">{q.sub}</span>
          </p>
          <p class="mt-3 text-pretty text-base leading-relaxed text-ink/90">{q.body}</p>
        </div>
      ))
    }
  </div>
</div>
