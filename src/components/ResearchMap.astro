---
import { researchFramework } from '../data/cv';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const quadrants = [
  {
    key: 'why',
    label: 'Why',
    body: researchFramework.why,
  },
  {
    key: 'who',
    label: 'Who',
    body: researchFramework.who,
  },
  {
    key: 'what',
    label: 'What',
    body: researchFramework.what,
  },
  {
    key: 'how',
    label: 'How',
    body: researchFramework.how,
  },
] as const;
---

<div class:list={[className ?? 'mt-6']}>
  <h2 class="font-serif text-xl font-semibold text-ink sm:text-2xl">Research framework</h2>

  <div class="mt-4" role="img" aria-label="Research framework: why, who, what, how">
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        quadrants.map((q) => (
          <article class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
            <p class="font-serif text-3xl font-semibold text-ink">{q.label}</p>
            <p class="mt-3 text-base leading-relaxed text-ink/90">{q.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</div>
