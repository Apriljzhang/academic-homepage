---
import { researchFramework } from '../data/cv';
import CrystalCard from './CrystalCard.astro';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const quadrants = [
  {
    key: 'why',
    label: 'Why',
    body: researchFramework.why,
  },
  {
    key: 'who',
    label: 'Who',
    body: researchFramework.who,
  },
  {
    key: 'what',
    label: 'What',
    body: researchFramework.what,
  },
  {
    key: 'how',
    label: 'How',
    body: researchFramework.how,
  },
] as const;
---

<div class:list={[className ?? 'mt-6']}>
  <h2 class="font-serif text-xl font-semibold text-ink sm:text-2xl">Research framework</h2>

  <CrystalCard
    as="div"
    padding="md"
    class="mt-4"
    role="img"
    aria-label="Research framework: why, who, what, how"
  >
    <div class="divide-y divide-border/70">
      {
        quadrants.map((q) => (
          <div class="grid grid-cols-[4.5rem_1fr] gap-3 py-3 first:pt-1 last:pb-1 sm:grid-cols-[5.25rem_1fr] sm:gap-4 sm:py-3.5">
            <p class="pt-0.5 font-serif text-base font-semibold text-ink sm:text-lg">{q.label}</p>
            <p class="text-sm leading-6 text-ink/90 sm:text-[0.95rem] sm:leading-6">{q.body}</p>
          </div>
        ))
      }
    </div>
  </CrystalCard>
</div>
