---
import { summary, researchInterests } from '../data/cv';
---

<p class="mt-6 max-w-4xl text-pretty text-lg leading-relaxed text-ink/95">
  {summary}
</p>
<h2 class="mt-14 font-serif text-2xl font-semibold text-ink">Research interests</h2>
<p class="mt-4 max-w-4xl text-pretty text-lg leading-relaxed text-muted">
  {researchInterests.intro}
</p>
<ul class="mt-8 grid gap-4 sm:grid-cols-1 lg:grid-cols-2">
  {
    researchInterests.themes.map(({ title, text }) => (
      <li class="rounded-lg border border-border/60 bg-primary-faint/40 px-5 py-4">
        <p class="font-semibold text-ink">{title}</p>
        <p class="mt-2 text-sm leading-relaxed text-muted">{text}</p>
      </li>
    ))
  }
</ul>
