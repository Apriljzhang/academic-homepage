---
import { grants } from '../data/cv';
---

<div class="mt-6 space-y-6">
  {
    grants.map((g) => (
      <div class="border-l-2 border-primary/25 pl-5">
        <p class="text-pretty text-lg font-medium leading-relaxed text-ink">{g.title}</p>
        <p class="mt-2 text-base text-muted">{g.role} · {g.years}</p>
        <p class="mt-1 text-base leading-relaxed text-muted">{g.institution}</p>
      </div>
    ))
  }
</div>
