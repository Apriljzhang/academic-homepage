---
import { person } from '../data/cv';
---

<footer
  class="w-full border-t border-border/60 bg-gradient-to-r from-primary-faint/40 via-blush-faint/30 to-secondary-faint/40 px-5 py-10 sm:px-8 md:px-12 lg:px-16 xl:px-20 2xl:px-24"
>
  <p class="text-sm text-muted">
    © {new Date().getFullYear()} {person.fullDisplayName}. British English site; publication titles appear as originally
    published.
  </p>
</footer>
