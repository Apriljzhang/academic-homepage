---
import { summary, researchInterests } from '../data/cv';
---

<section id="about" class="scroll-mt-20 border-b border-border/50 bg-surface px-4 py-14 sm:px-6">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-serif text-2xl font-semibold text-ink">About</h2>
    <p class="mt-4 max-w-prose text-pretty leading-relaxed text-ink/95">
      {summary}
    </p>
    <h3 class="mt-10 font-serif text-xl font-semibold text-ink">Research interests</h3>
    <p class="mt-3 max-w-prose text-pretty text-muted leading-relaxed">
      {researchInterests.intro}
    </p>
    <ul class="mt-6 space-y-5">
      {
        researchInterests.themes.map(({ title, text }) => (
          <li class="rounded-lg border border-border/60 bg-primary-faint/40 px-4 py-3">
            <p class="font-semibold text-ink">{title}</p>
            <p class="mt-1 text-sm leading-relaxed text-muted">{text}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
