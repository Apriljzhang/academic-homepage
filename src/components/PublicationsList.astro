---
import { publications, publicationsUnderReview } from '../data/cv';
import { googleScholarProfileUrl } from '../data/profiles';
---

<ol class="mt-8 list-decimal space-y-8 pl-5 marker:font-serif marker:text-lg marker:text-primary">
  {
    publications.map((item) => (
      <li class="pl-2">
        {item.note ? (
          <span class="mb-1 inline-block rounded-full bg-primary-faint px-2 py-0.5 text-xs font-semibold text-ink">
            {item.note}
          </span>
        ) : null}
        <p
          class="mt-1 text-pretty text-lg leading-relaxed text-ink/95 [&_em]:font-serif [&_em]:italic [&_em]:text-primary"
          set:html={item.citationHtml}
        />
        {item.scholarHref ? (
          <p class="mt-2">
            <a
              href={item.scholarHref}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-primary no-underline hover:underline"
            >
              View on Google Scholar
            </a>
          </p>
        ) : null}
      </li>
    ))
  }
</ol>

{
  publicationsUnderReview.length > 0 ? (
    <>
      <h2 class="mt-16 font-serif text-2xl font-semibold text-ink">Under review</h2>
      <ol class="mt-6 list-decimal space-y-6 pl-5 marker:font-serif marker:text-primary">
        {publicationsUnderReview.map((item) => (
          <li class="pl-2">
            {item.note ? (
              <span class="mb-1 inline-block rounded-full bg-accent-pink/60 px-2 py-0.5 text-xs font-semibold text-ink">
                {item.note}
              </span>
            ) : null}
            <p
              class="mt-1 text-pretty text-lg leading-relaxed text-ink/95 [&_em]:font-serif [&_em]:italic [&_em]:text-primary"
              set:html={item.citationHtml}
            />
          </li>
        ))}
      </ol>
    </>
  ) : null
}

<p class="mt-12 text-sm text-muted">
  Citations and any further items appear on{' '}
  <a href={googleScholarProfileUrl} target="_blank" rel="noopener noreferrer" class="font-semibold text-primary">
    Google Scholar →
  </a>
</p>
