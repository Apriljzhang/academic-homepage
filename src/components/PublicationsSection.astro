---
import { publications } from '../data/cv';
---

<section id="publications" class="scroll-mt-20 border-b border-border/50 bg-surface px-4 py-14 sm:px-6">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-serif text-2xl font-semibold text-ink">Publications</h2>
    <p class="mt-2 text-sm text-muted">Selected peer-reviewed and forthcoming work.</p>
    <ol class="mt-8 list-decimal space-y-6 pl-5 marker:font-serif marker:text-primary">
      {
        publications.map((item) => (
          <li class="pl-1">
            {item.note ? (
              <span class="mb-1 inline-block rounded-full bg-accent-pink/60 px-2 py-0.5 text-xs font-semibold text-ink">
                {item.note}
              </span>
            ) : null}
            <p
              class="mt-1 text-pretty leading-relaxed text-ink/95 [&_em]:font-serif [&_em]:italic [&_em]:text-primary"
              set:html={item.citationHtml}
            />
          </li>
        ))
      }
    </ol>
  </div>
</section>
