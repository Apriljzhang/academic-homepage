---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageShell from '../components/PageShell.astro';
import TalksList from '../components/TalksList.astro';
import { person } from '../data/cv';

const title = `Service · ${person.fullDisplayName}`;
const description = `Conference presentations and professional engagement — ${person.fullDisplayName}.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-surface">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Service</h1>
      <p class="mt-4 max-w-4xl text-lg text-muted">
        Selected conference presentations and scholarly dissemination (further service roles can be added here as needed).
      </p>
      <h2 class="mt-10 font-serif text-2xl font-semibold text-ink">Conference presentations</h2>
      <TalksList />
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
