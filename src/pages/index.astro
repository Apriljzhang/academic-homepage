---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageShell from '../components/PageShell.astro';
import MainWithAside from '../components/MainWithAside.astro';
import AboutSectionAside from '../components/AboutSectionAside.astro';
import { person, aboutNarrativeParagraphs } from '../data/cv';

const title = `${person.fullDisplayName} · ${person.title}`;
const description = `${person.fullDisplayName}, ${person.title} at ${person.affiliation}. Language education, formative assessment, and language testing.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="bg-page">
    <Hero />
    <PageShell>
      <MainWithAside asideLabel="About" wide>
        <section id="about" class="scroll-mt-24">
          <h2 class="font-serif text-2xl font-semibold text-ink sm:text-3xl">About</h2>
          <div class="mt-6 max-w-3xl space-y-5 text-pretty text-base leading-relaxed text-ink/95 sm:text-lg">
            {aboutNarrativeParagraphs.map((p) => <p>{p}</p>)}
          </div>
        </section>
        <AboutSectionAside slot="aside" />
      </MainWithAside>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
