---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageShell from '../components/PageShell.astro';
import { person, aboutNarrativeParagraphs } from '../data/cv';

const title = `About · ${person.fullDisplayName}`;
const description = `${person.fullDisplayName} — researcher in language education and assessment.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-surface">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">About</h1>

      <div class="mt-10 max-w-3xl space-y-6 text-pretty text-lg leading-relaxed text-ink/95 lg:text-xl">
        {aboutNarrativeParagraphs.map((p) => <p>{p}</p>)}
      </div>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
