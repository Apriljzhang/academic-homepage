---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageShell from '../components/PageShell.astro';
import MainWithAside from '../components/MainWithAside.astro';
import AboutSectionAside from '../components/AboutSectionAside.astro';
import { person, aboutNarrativeParagraphs } from '../data/cv';

const title = `About · ${person.fullDisplayName}`;
const description = `${person.fullDisplayName} — researcher in language education and assessment.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-0 w-full bg-page">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">About</h1>
      <MainWithAside asideLabel="About">
        <div>
          <section id="about-intro" class="scroll-mt-24">
            <div class="mt-6 max-w-3xl space-y-5 text-pretty text-base leading-relaxed text-ink/95 sm:text-lg">
              {aboutNarrativeParagraphs.map((p) => <p>{p}</p>)}
            </div>
          </section>
        </div>
        <AboutSectionAside slot="aside" />
      </MainWithAside>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
