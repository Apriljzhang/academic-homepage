---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageShell from '../components/PageShell.astro';
import { person, aboutPageLead } from '../data/cv';

const profileSrc = `${import.meta.env.BASE_URL.replace(/\/?$/, '/')}images/profile.jpg`;
const title = `About · ${person.fullDisplayName}`;
const description = `${person.fullDisplayName} — research profile.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-surface">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">About</h1>

      <div
        class="mt-10 flex flex-col items-stretch gap-10 lg:mt-14 lg:flex-row lg:items-start lg:gap-14 xl:gap-20"
      >
        <div class="mx-auto w-full max-w-md shrink-0 lg:mx-0 lg:max-w-lg xl:max-w-2xl">
          <div
            class="overflow-hidden rounded-2xl border-4 border-white bg-surface shadow-2xl shadow-secondary/20 ring-2 ring-accent-yellow/50"
          >
            <img
              src={profileSrc}
              alt="April Jiawei Zhang 張家維"
              width="960"
              height="1200"
              class="h-auto w-full object-cover"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
        <p class="max-w-prose text-pretty text-lg leading-relaxed text-ink/95 lg:pt-2 lg:text-xl">
          {aboutPageLead}
        </p>
      </div>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
