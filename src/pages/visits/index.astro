---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import CrystalCard from '../../components/CrystalCard.astro';
import WorldMap from '../../components/visits/WorldMap';
import { person } from '../../data/cv';
import { getCollaborators } from '../../data/collaborators';

const title = `Connections · ${person.fullDisplayName}`;
const description = `Connections and visitor locations — ${person.fullDisplayName}.`;

const countsUrl = import.meta.env.PUBLIC_SUPABASE_VISIT_COUNTS_URL as string | undefined;

type CountRow = {
  country: string | null;
  region: string | null;
  city: string | null;
  lat: number | null;
  lng: number | null;
  count: number;
};

let rows: CountRow[] = [];
if (countsUrl) {
  const res = await fetch(countsUrl, { headers: { accept: 'application/json' } });
  if (res.ok) {
    const json = (await res.json()) as { ok: boolean; data?: CountRow[] };
    if (json.ok && Array.isArray(json.data)) rows = json.data;
  }
}

const dots = rows
  .filter((r) => typeof r.lat === 'number' && typeof r.lng === 'number')
  .slice(0, 80)
  .map((r) => ({
    lat: r.lat as number,
    lng: r.lng as number,
    label: [r.city, r.region, r.country].filter(Boolean).join(', ') || 'Unknown',
    count: r.count,
  }));

const collaborators = getCollaborators();

const macau = { lat: 22.1987, lng: 113.5439, label: 'Macau' };
const collaboratorRoutes = collaborators
  .filter((c) => typeof c.lat === 'number' && typeof c.lng === 'number')
  .map((c) => ({
    start: macau,
    end: { lat: c.lat as number, lng: c.lng as number, label: `${c.name} (${c.affiliation ?? ''})`.trim() },
  }));
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-page">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Connections</h1>

      <div class="mt-10 grid gap-6 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-start">
        <div class="min-w-0">
          <WorldMap
            client:load
            dots={dots}
            routes={collaboratorRoutes}
            visitorColor="#659dbd"
            collaboratorColor="#c9492a"
          />
        </div>
        <div class="space-y-4">
          <CrystalCard as="div">
            <p class="text-xs font-bold uppercase tracking-wider text-muted">Top regions (last 30 days)</p>
            <ol class="mt-4 space-y-2 text-sm">
              {rows.slice(0, 12).map((r) => (
                <li class="flex items-start justify-between gap-3">
                  <span class="text-ink/90">
                    {[r.city, r.region, r.country].filter(Boolean).join(', ') || 'Unknown'}
                  </span>
                  <span class="shrink-0 rounded-full border border-border bg-page px-2 py-1 text-xs font-semibold text-ink">
                    {r.count}
                  </span>
                </li>
              ))}
            </ol>
          </CrystalCard>
          <CrystalCard as="div" padding="md">
            <p class="font-serif text-lg font-semibold text-ink">Notes</p>
            <ul class="mt-2 space-y-2 text-sm text-muted">
              <li>- Counts are approximate and based on best-effort IP geolocation.</li>
              <li>- We store a salted hash of IP, not the raw IP address.</li>
              <li>- Tracking runs once per browser session.</li>
            </ul>
          </CrystalCard>
        </div>
      </div>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>

