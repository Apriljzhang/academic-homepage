---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import VisitsDashboard from '../../components/visits/VisitsDashboard';
import { person } from '../../data/cv';
import { getCollaborators } from '../../data/collaborators';

const title = `Hello to Collaborators and Visitors · ${person.fullDisplayName}`;
const description = `Hello to collaborators and visitors — map and regional visits for ${person.fullDisplayName}.`;

const countsUrl = (import.meta.env.PUBLIC_SUPABASE_VISIT_COUNTS_URL as string | undefined) ?? '';

const collaborators = getCollaborators();

const macau = { lat: 22.1987, lng: 113.5439, label: 'Macau' };
const collaboratorRoutes = collaborators
  .filter((c) => typeof c.lat === 'number' && typeof c.lng === 'number')
  .map((c) => ({
    start: macau,
    end: { lat: c.lat as number, lng: c.lng as number, label: `${c.name} (${c.affiliation ?? ''})`.trim() },
  }));

---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-page">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Hello to Collaborators and Visitors</h1>
      <VisitsDashboard client:load countsUrl={countsUrl} collaboratorRoutes={collaboratorRoutes} home={macau} />
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>

