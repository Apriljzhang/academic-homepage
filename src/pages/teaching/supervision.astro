---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import SectionSubnav from '../../components/SectionSubnav.astro';
import SupervisionTables from '../../components/SupervisionTables.astro';
import { teachingSubnav } from '../../data/sectionNav';
import { person } from '../../data/cv';

const title = `Supervision · ${person.fullDisplayName}`;
const description = `Dissertation and thesis supervision — ${person.fullDisplayName}.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-0 w-full bg-surface">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Supervision</h1>
      <SectionSubnav ariaLabel="Teaching section" items={teachingSubnav} />
      <SupervisionTables />
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
