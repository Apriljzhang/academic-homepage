---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import SectionSubnav from '../../components/SectionSubnav.astro';
import MainWithAside from '../../components/MainWithAside.astro';
import TeachingSectionAside from '../../components/TeachingSectionAside.astro';
import SupervisionTables from '../../components/SupervisionTables.astro';
import { teachingSubnav } from '../../data/sectionNav';
import { person } from '../../data/cv';

const title = `Supervision · ${person.fullDisplayName}`;
const description = `Dissertation and thesis supervision — ${person.fullDisplayName}.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-0 w-full bg-page">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Supervision</h1>
      <MainWithAside asideLabel="Teaching menu">
        <div>
          <SectionSubnav ariaLabel="Teaching section" items={teachingSubnav} />
          <p class="mt-4 max-w-3xl text-pretty text-lg leading-relaxed text-muted lg:text-xl">
            I supervise dissertations and theses in language education, assessment, and technology-enhanced learning for Master and Doctoral students.
          </p>
          <SupervisionTables />
        </div>
        <TeachingSectionAside slot="aside" />
      </MainWithAside>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
