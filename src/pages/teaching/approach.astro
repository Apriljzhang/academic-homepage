---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import SectionSubnav from '../../components/SectionSubnav.astro';
import MainWithAside from '../../components/MainWithAside.astro';
import TeachingSectionAside from '../../components/TeachingSectionAside.astro';
import { teachingSubnav } from '../../data/sectionNav';
import {
  person,
  teachingCoursesMastersCityU,
  teachingCoursesDoctoralCityU,
  teachingPhilosophyParagraphs,
  teachingNarrativeParagraphs,
} from '../../data/cv';

const title = `Teaching approach · ${person.fullDisplayName}`;
const description = `Teaching philosophy and experience — ${person.fullDisplayName}.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-0 w-full bg-page">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">
        Approach &amp; experience
      </h1>
      <MainWithAside asideLabel="Teaching menu">
        <div>
          <SectionSubnav ariaLabel="Teaching section" items={teachingSubnav} />

          <h2 class="mt-6 font-serif text-xl font-semibold text-ink sm:text-2xl">Current courses (CityU)</h2>
          <div class="mt-4 grid max-w-4xl gap-8 lg:grid-cols-2 lg:gap-10">
            <div>
              <h3 class="text-xs font-bold uppercase tracking-wider text-secondary">MA / MEd courses</h3>
              <ul class="mt-3 flex flex-col gap-2">
                {
                  teachingCoursesMastersCityU.map((c) => (
                    <li class="rounded-lg border border-border bg-surface px-3 py-2 text-sm">
                      <span class="font-mono font-semibold text-primary">{c.code}</span>
                      <span class="text-ink"> — {c.name}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
            <div>
              <h3 class="text-xs font-bold uppercase tracking-wider text-secondary">PhD / Doctoral courses</h3>
              <ul class="mt-3 flex flex-col gap-2">
                {
                  teachingCoursesDoctoralCityU.map((c) => (
                    <li class="rounded-lg border border-border bg-surface px-3 py-2 text-sm">
                      <span class="font-mono font-semibold text-primary">{c.code}</span>
                      <span class="text-ink"> — {c.name}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>

          <h2 class="mt-8 font-serif text-xl font-semibold text-ink sm:text-2xl">Philosophy and methods</h2>
          <div class="mt-4 max-w-3xl space-y-3 text-pretty text-base leading-relaxed text-ink/95 sm:text-lg">
            {teachingPhilosophyParagraphs.map((p) => <p>{p}</p>)}
          </div>

          <h2 class="mt-8 font-serif text-xl font-semibold text-ink sm:text-2xl">Trajectory: UK and China / Macau</h2>
          <div class="mt-4 max-w-3xl space-y-3 text-pretty text-base leading-relaxed text-ink/95 sm:text-lg">
            {teachingNarrativeParagraphs.map((p) => <p>{p}</p>)}
          </div>
        </div>
        <TeachingSectionAside slot="aside" />
      </MainWithAside>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
