---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import SectionSubnav from '../../components/SectionSubnav.astro';
import MainWithAside from '../../components/MainWithAside.astro';
import ServiceSectionAside from '../../components/ServiceSectionAside.astro';
import TalksList from '../../components/TalksList.astro';
import { serviceSubnav } from '../../data/sectionNav';
import { person } from '../../data/cv';

const title = `Presentations · ${person.fullDisplayName}`;
const description = `Conference presentations — ${person.fullDisplayName}.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-page">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Presentations</h1>
      <MainWithAside asideLabel="Service menu">
        <div>
          <SectionSubnav ariaLabel="Service section" items={serviceSubnav} />
          <TalksList />
        </div>
        <ServiceSectionAside slot="aside" />
      </MainWithAside>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
