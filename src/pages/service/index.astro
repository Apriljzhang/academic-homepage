---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import SectionSubnav from '../../components/SectionSubnav.astro';
import MainWithAside from '../../components/MainWithAside.astro';
import ServiceSectionAside from '../../components/ServiceSectionAside.astro';
import ProfessionalMembershipsContent from '../../components/ProfessionalMembershipsContent.astro';
import { serviceSubnav } from '../../data/sectionNav';
import { person } from '../../data/cv';
import { withBase } from '../../utils/paths';

const title = `Service · ${person.fullDisplayName}`;
const description = `Professional service, conference organisation, presentations, and memberships — ${person.fullDisplayName}.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-page">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Service</h1>
      <MainWithAside asideLabel="Service menu">
        <div>
          <p class="mt-4 max-w-3xl text-pretty text-lg leading-relaxed text-muted lg:text-xl">
            Conference leadership, scholarly networks, and selected presentations in language assessment and language
            education.
          </p>
          <SectionSubnav ariaLabel="Service section" items={serviceSubnav} />

          <ul class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            <li class="rounded-xl border border-border bg-surface p-5">
              <a
                href={withBase('/service/organisation')}
                class="font-serif text-lg font-semibold text-ink no-underline hover:text-primary"
              >
                Conference organisation →
              </a>
              <p class="mt-2 text-sm text-muted">AALA 2026 co-chair and host institution role at City University of Macau.</p>
            </li>
            <li class="rounded-xl border border-border bg-surface p-5">
              <a
                href={withBase('/service/presentations')}
                class="font-serif text-lg font-semibold text-ink no-underline hover:text-primary"
              >
                Presentations →
              </a>
              <p class="mt-2 text-sm text-muted">Selected conference talks and forums.</p>
            </li>
            <li class="rounded-xl border border-border bg-surface p-5 md:col-span-2 lg:col-span-1">
              <a
                href="#memberships"
                class="font-serif text-lg font-semibold text-ink no-underline hover:text-primary"
              >
                Professional memberships →
              </a>
              <p class="mt-2 text-sm text-muted">Learned societies and professional networks in language assessment and education.</p>
            </li>
          </ul>

          <ProfessionalMembershipsContent variant="inline" />
        </div>
        <ServiceSectionAside slot="aside" />
      </MainWithAside>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
