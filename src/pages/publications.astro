---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageShell from '../components/PageShell.astro';
import PublicationsList from '../components/PublicationsList.astro';
import { person } from '../data/cv';

const title = `Publications · ${person.fullDisplayName}`;
const description = `Publications and thesis by ${person.fullDisplayName} — journal articles and PhD research, with links to Google Scholar.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-surface">
    <PageShell>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl">Publications</h1>
      <p class="mt-4 max-w-4xl text-lg leading-relaxed text-muted">
        List aligned with my{' '}
        <a
          href="https://scholar.google.com/citations?user=UXwVmZ8AAAAJ&hl=en"
          target="_blank"
          rel="noopener noreferrer"
          >Google Scholar</a
        >
        profile (articles and thesis). Under-review work is listed separately below the main list.
      </p>
      <PublicationsList />
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
