---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageShell from '../components/PageShell.astro';
import TalksList from '../components/TalksList.astro';
import { person } from '../data/cv';

const title = `Conference presentations · ${person.fullDisplayName}`;
const description = `Selected conference presentations — ${person.fullDisplayName}, language education and assessment.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-surface">
    <PageShell>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl">Conference presentations</h1>
      <p class="mt-4 max-w-4xl text-lg text-muted">Selected talks (reverse chronological where noted).</p>
      <TalksList />
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
