---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import MainWithAside from '../../components/MainWithAside.astro';
import CrystalCard from '../../components/CrystalCard.astro';
import { person } from '../../data/cv';
import { contact } from '../../data/contact';
import { SUPABASE_URL, supabaseRestHeaders } from '../../utils/supabasePublic';
import { marked } from 'marked';

export async function getStaticPaths() {
  if (!SUPABASE_URL) return [];
  const url =
    `${SUPABASE_URL}/rest/v1/blog_posts?select=slug,published_at` +
    `&published_at=not.is.null&published_at=lte.${encodeURIComponent(new Date().toISOString())}` +
    `&order=published_at.desc`;
  const res = await fetch(url, { headers: { ...supabaseRestHeaders() } });
  if (!res.ok) return [];
  const posts = (await res.json()) as Array<{ slug: string }>;
  return posts.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

type Post = {
  slug: string;
  title: string;
  excerpt: string | null;
  content_md: string;
  cover_image_url: string | null;
  tags: string[];
  published_at: string;
};
type PostListItem = {
  slug: string;
  title: string;
};

let post: Post | null = null;
let otherPosts: PostListItem[] = [];
if (SUPABASE_URL && slug) {
  const url =
    `${SUPABASE_URL}/rest/v1/blog_posts?select=slug,title,excerpt,content_md,cover_image_url,tags,published_at` +
    `&slug=eq.${encodeURIComponent(slug)}&limit=1`;
  const res = await fetch(url, { headers: { ...supabaseRestHeaders() } });
  if (res.ok) {
    const data = (await res.json()) as Post[];
    post = data[0] ?? null;
  }

  const listUrl =
    `${SUPABASE_URL}/rest/v1/blog_posts?select=slug,title,published_at` +
    `&published_at=not.is.null&published_at=lte.${encodeURIComponent(new Date().toISOString())}` +
    `&order=published_at.desc&limit=9`;
  const listRes = await fetch(listUrl, { headers: { ...supabaseRestHeaders() } });
  if (listRes.ok) {
    const rows = (await listRes.json()) as Array<PostListItem & { published_at: string }>;
    otherPosts = rows.filter((p) => p.slug !== slug).slice(0, 8);
  }
}

if (!post) {
  return Astro.redirect('/blog/');
}

const title = `${post.title} · Blog · ${person.fullDisplayName}`;
const description = post.excerpt ?? `Blog post — ${person.fullDisplayName}.`;
const trackBlogVisitUrl = (import.meta.env.PUBLIC_SUPABASE_TRACK_BLOG_VISIT_URL as string | undefined) ?? '';

const html = marked.parse(post.content_md);
const replyTo = `mailto:${contact.cityu}?subject=${encodeURIComponent(`Reply: ${post.title}`)}`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-page">
    <PageShell accentBar>
      <MainWithAside asideLabel="Blog">
        <div>
          <a href="/blog/" class="text-sm font-semibold text-primary no-underline hover:underline">← Back to Blog</a>
          <button
            type="button"
            id="blog-cite-btn"
            class="ml-3 rounded-full border border-border bg-page px-3 py-1 text-xs font-semibold text-muted hover:bg-neutral-hover hover:text-ink"
          >
            Cite
          </button>
          <a id="blog-edit-link" href={`/blog/admin/?slug=${encodeURIComponent(post.slug)}`} class="ml-3 hidden text-sm font-semibold text-muted no-underline hover:underline">
            Edit
          </a>
          <h1 class="mt-4 font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl">{post.title}</h1>
          <p class="mt-2 text-sm text-muted">
            {new Date(post.published_at).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: '2-digit' })}
          </p>

          {post.cover_image_url ? (
            <div class="mt-6 overflow-hidden rounded-xl border border-border bg-surface shadow-sm">
              <img src={post.cover_image_url} alt="" class="h-auto w-full object-cover" loading="lazy" />
            </div>
          ) : null}

          <article class="mt-8 max-w-none space-y-4 text-pretty text-base leading-relaxed text-ink/95">
            <Fragment set:html={html} />
          </article>

          <CrystalCard as="div" padding="md" class="mt-10">
            <p class="font-serif text-lg font-semibold text-ink">Reply</p>
            <p class="mt-2 text-sm text-muted">
              No login needed. Please reply by email and include the post title.
            </p>
            <a href={replyTo} class="mt-3 inline-block text-sm font-semibold text-primary no-underline hover:underline">
              Reply by email →
            </a>
          </CrystalCard>
        </div>
        <div slot="aside" class="text-sm text-muted">
          <p class="text-xs font-bold uppercase tracking-wider text-muted">Tags</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {post.tags?.map((t) => <span class="rounded-full border border-border bg-surface px-2 py-1 text-xs font-semibold text-ink">{t}</span>)}
          </div>
          <p class="mt-8 text-xs font-bold uppercase tracking-wider text-muted">Other posts</p>
          {otherPosts.length ? (
            <ul class="mt-3 space-y-2">
              {otherPosts.map((p) => (
                <li>
                  <a href={`/blog/${encodeURIComponent(p.slug)}/`} class="text-sm font-semibold text-primary no-underline hover:underline">
                    {p.title}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-3">No other posts yet.</p>
          )}
        </div>
      </MainWithAside>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>

<script define:vars={{ trackBlogVisitUrl, postSlug: post.slug, postTitle: post.title, postDate: post.published_at }}>
  (() => {
    const a = document.getElementById("blog-edit-link");
    if (!(a instanceof HTMLAnchorElement)) return;
    try {
      const key = (window.sessionStorage.getItem("BLOG_ADMIN_KEY") ?? "").trim();
      if (key.length > 0) {
        a.classList.remove("hidden");
      }
    } catch {}
  })();

  (() => {
    try {
      const fn = trackBlogVisitUrl || "";
      const slug = postSlug || "";
      if (!fn || !slug) return;
      const key = `blog-visit-tracked-v1:${slug}`;
      if (window.sessionStorage.getItem(key)) return;
      window.sessionStorage.setItem(key, "1");
      fetch(fn, {
        method: "POST",
        mode: "cors",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ slug }),
      }).catch(() => {});
    } catch {}
  })();

  (() => {
    const btn = document.getElementById("blog-cite-btn");
    if (!(btn instanceof HTMLButtonElement)) return;
    btn.addEventListener("click", async () => {
      try {
        const origin = window.location.origin.replace(/\/+$/, "");
        const slug = String(postSlug || "");
        const title = String(postTitle || "");
        const d = new Date(String(postDate || ""));
        const datePart = Number.isNaN(d.getTime())
          ? "n.d."
          : d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
        const postUrl = `${origin}/blog/${encodeURIComponent(slug)}/`;
        const apa = `Zhang, A. J. (${datePart}). ${title} [Blog post]. Reflexivity in Research, Learning, and Teaching-AJZ. ${postUrl}`;
        const year = Number.isNaN(d.getTime()) ? "n.d." : String(d.getFullYear());
        const months = ["jan", "feb", "mar", "apr", "may", "jun", "jul", "aug", "sep", "oct", "nov", "dec"];
        const month = Number.isNaN(d.getTime()) ? "jan" : months[d.getMonth()];
        const day = Number.isNaN(d.getTime()) ? "1" : String(d.getDate());
        const keyPart = slug.toLowerCase().replace(/[^a-z0-9]+/g, "").slice(0, 24) || "post";
        const bib = [
          `@online{zhang${year}${keyPart},`,
          `  author = {Zhang, April Jiawei},`,
          `  title = {${title.replace(/\\/g, "\\\\").replace(/\{/g, "\\{").replace(/\}/g, "\\}")}},`,
          `  year = {${year}},`,
          `  month = {${month}},`,
          `  day = {${day}},`,
          `  howpublished = {Reflexivity in Research, Learning, and Teaching-AJZ},`,
          `  url = {${postUrl}}`,
          `}`,
        ].join("\n");
        await navigator.clipboard.writeText(`APA 7th\n${apa}\n\nBibTeX\n${bib}`);
        window.alert("Citation copied via BibTeX.");
      } catch {
        window.alert("Could not copy citation.");
      }
    });
  })();
</script>

