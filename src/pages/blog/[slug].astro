---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import MainWithAside from '../../components/MainWithAside.astro';
import CrystalCard from '../../components/CrystalCard.astro';
import { person } from '../../data/cv';
import { contact } from '../../data/contact';
import { SUPABASE_URL, supabaseRestHeaders } from '../../utils/supabasePublic';
import { marked } from 'marked';

export async function getStaticPaths() {
  if (!SUPABASE_URL) return [];
  const url =
    `${SUPABASE_URL}/rest/v1/blog_posts?select=slug,published_at` +
    `&published_at=not.is.null&published_at=lte.${encodeURIComponent(new Date().toISOString())}` +
    `&order=published_at.desc`;
  const res = await fetch(url, { headers: { ...supabaseRestHeaders() } });
  if (!res.ok) return [];
  const posts = (await res.json()) as Array<{ slug: string }>;
  return posts.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

type Post = {
  slug: string;
  title: string;
  excerpt: string | null;
  content_md: string;
  cover_image_url: string | null;
  tags: string[];
  published_at: string;
};

let post: Post | null = null;
if (SUPABASE_URL && slug) {
  const url =
    `${SUPABASE_URL}/rest/v1/blog_posts?select=slug,title,excerpt,content_md,cover_image_url,tags,published_at` +
    `&slug=eq.${encodeURIComponent(slug)}&limit=1`;
  const res = await fetch(url, { headers: { ...supabaseRestHeaders() } });
  if (res.ok) {
    const data = (await res.json()) as Post[];
    post = data[0] ?? null;
  }
}

if (!post) {
  return Astro.redirect('/blog/');
}

const title = `${post.title} · Blog · ${person.fullDisplayName}`;
const description = post.excerpt ?? `Blog post — ${person.fullDisplayName}.`;

const html = marked.parse(post.content_md);
const replyTo = `mailto:${contact.cityu}?subject=${encodeURIComponent(`Reply: ${post.title}`)}`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-page">
    <PageShell accentBar>
      <MainWithAside asideLabel="Blog">
        <div>
          <a href="/blog/" class="text-sm font-semibold text-primary no-underline hover:underline">← Back to Blog</a>
          <h1 class="mt-4 font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl">{post.title}</h1>
          <p class="mt-2 text-sm text-muted">
            {new Date(post.published_at).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: '2-digit' })}
          </p>

          {post.cover_image_url ? (
            <div class="mt-6 overflow-hidden rounded-xl border border-border bg-surface shadow-sm">
              <img src={post.cover_image_url} alt="" class="h-auto w-full object-cover" loading="lazy" />
            </div>
          ) : null}

          <article class="mt-8 max-w-none space-y-4 text-pretty text-base leading-relaxed text-ink/95">
            <Fragment set:html={html} />
          </article>

          <CrystalCard as="div" padding="md" class="mt-10">
            <p class="font-serif text-lg font-semibold text-ink">Reply</p>
            <p class="mt-2 text-sm text-muted">
              No login needed. Please reply by email and include the post title.
            </p>
            <a href={replyTo} class="mt-3 inline-block text-sm font-semibold text-primary no-underline hover:underline">
              Reply by email →
            </a>
          </CrystalCard>
        </div>
        <div slot="aside" class="text-sm text-muted">
          <p class="text-xs font-bold uppercase tracking-wider text-muted">Tags</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {post.tags?.map((t) => <span class="rounded-full border border-border bg-surface px-2 py-1 text-xs font-semibold text-ink">{t}</span>)}
          </div>
        </div>
      </MainWithAside>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>

