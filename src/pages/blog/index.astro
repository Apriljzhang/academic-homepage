---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import MainWithAside from '../../components/MainWithAside.astro';
import BlogCalendarGate from '../../components/blog/BlogCalendarGate';
import BlogPostGrid from '../../components/blog/BlogPostGrid';
import BlogFiltersAside from '../../components/blog/BlogFiltersAside';
import { person } from '../../data/cv';
import { SUPABASE_URL, supabaseRestHeaders } from '../../utils/supabasePublic';

const title = `Blog · ${person.fullDisplayName}`;
const description = `Educational and research notes — ${person.fullDisplayName}.`;
const blogViewCountsUrl = (import.meta.env.PUBLIC_SUPABASE_BLOG_VIEW_COUNTS_URL as string | undefined) ?? '';

type Post = {
  id: string;
  slug: string;
  title: string;
  excerpt: string | null;
  cover_image_url: string | null;
  tags: string[];
  published_at: string;
};

let posts: Post[] = [];
if (SUPABASE_URL) {
  const pageSize = 200;
  let offset = 0;
  for (;;) {
    const url =
      `${SUPABASE_URL}/rest/v1/blog_posts?select=id,slug,title,excerpt,cover_image_url,tags,published_at` +
      `&published_at=not.is.null&published_at=lte.${encodeURIComponent(new Date().toISOString())}` +
      `&order=published_at.desc&limit=${pageSize}&offset=${offset}`;
    const res = await fetch(url, { headers: { ...supabaseRestHeaders() } });
    if (!res.ok) break;
    const chunk = (await res.json()) as Post[];
    posts.push(...chunk);
    if (chunk.length < pageSize) break;
    offset += pageSize;
    if (offset > 10000) break;
  }
}
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-page">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Blog</h1>
      <MainWithAside asideLabel="Blog filters">
        <div>
          <p class="mt-4 max-w-3xl text-pretty text-lg leading-relaxed text-muted lg:text-xl">
            Educational and research notes. I believe learning is a shared dialogue—I value your voice in this space. To share your
            thoughts or start a conversation, please use the email link at the end of each post.
          </p>
          <div class="mt-4 grid gap-6 lg:grid-cols-[minmax(0,22rem)_minmax(0,1fr)] lg:items-start">
            <div class="order-2 lg:order-1">
              <BlogCalendarGate client:load posts={posts} />
            </div>
            <div class="order-1 lg:order-2">
              <BlogPostGrid client:load initialPosts={posts} countsUrl={blogViewCountsUrl} />
            </div>
          </div>
        </div>
        <BlogFiltersAside slot="aside" client:load initialPosts={posts} />
      </MainWithAside>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>

