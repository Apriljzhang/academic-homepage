---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import MainWithAside from '../../components/MainWithAside.astro';
import BlogCalendarGate from '../../components/blog/BlogCalendarGate';
import BlogPostGrid from '../../components/blog/BlogPostGrid';
import { person } from '../../data/cv';
import { SUPABASE_URL, supabaseRestHeaders } from '../../utils/supabasePublic';

const title = `Blog · ${person.fullDisplayName}`;
const description = `Educational and research notes — ${person.fullDisplayName}.`;

type Post = {
  id: string;
  slug: string;
  title: string;
  excerpt: string | null;
  cover_image_url: string | null;
  tags: string[];
  published_at: string;
};

let posts: Post[] = [];
if (SUPABASE_URL) {
  const url =
    `${SUPABASE_URL}/rest/v1/blog_posts?select=id,slug,title,excerpt,cover_image_url,tags,published_at` +
    `&published_at=not.is.null&published_at=lte.${encodeURIComponent(new Date().toISOString())}` +
    `&order=published_at.desc`;
  const res = await fetch(url, { headers: { ...supabaseRestHeaders() } });
  if (res.ok) posts = (await res.json()) as Post[];
}
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-page">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Blog</h1>
      <MainWithAside asideLabel="Blog">
        <div>
          <p class="mt-4 max-w-3xl text-pretty text-lg leading-relaxed text-muted lg:text-xl">
            Educational and research notes. I believe learning is a shared dialogue—I value your voice in this space. To share your
            thoughts or start a conversation, please use the email link at the end of each post.
          </p>

          <div class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,22rem)_minmax(0,1fr)] lg:items-start">
            <div class="order-2 lg:order-1">
              <BlogCalendarGate client:load posts={posts} />
            </div>
            <div class="order-1 lg:order-2">
              <BlogPostGrid client:load initialPosts={posts} />
            </div>
          </div>
        </div>
        <div slot="aside" class="hidden lg:block" />
      </MainWithAside>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>

