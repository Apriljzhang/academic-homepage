---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import SectionSubnav from '../../components/SectionSubnav.astro';
import MainWithAside from '../../components/MainWithAside.astro';
import ResearchSectionAside from '../../components/ResearchSectionAside.astro';
import PublicationsList from '../../components/PublicationsList.astro';
import { researchSubnav } from '../../data/sectionNav';
import { person } from '../../data/cv';

const title = `Publications · ${person.fullDisplayName}`;
const description = `Publications — ${person.fullDisplayName}.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-page">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Publications</h1>
      <MainWithAside asideLabel="Research menu">
        <div>
          <SectionSubnav ariaLabel="Research section" items={researchSubnav} />

          <h2 class="mt-10 font-serif text-2xl font-semibold text-ink">Published &amp; doctoral dissertation</h2>
          <PublicationsList />
        </div>
        <ResearchSectionAside slot="aside" />
      </MainWithAside>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
