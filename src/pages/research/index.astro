---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import SectionSubnav from '../../components/SectionSubnav.astro';
import { researchSubnav } from '../../data/sectionNav';
import { person } from '../../data/cv';
import { withBase } from '../../utils/paths';

const title = `Research · ${person.fullDisplayName}`;
const description = `Research interests, publications, and funded projects — ${person.fullDisplayName}.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-surface">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Research</h1>
      <p class="mt-4 max-w-3xl text-pretty text-lg leading-relaxed text-muted lg:text-xl">
        My work sits at the intersection of language education, classroom and formative assessment, and—more
        recently—technology and AI in language learning and testing. Use the links below to move between themes, outputs,
        and funded projects.
      </p>
      <SectionSubnav ariaLabel="Research section" items={researchSubnav} />

      <ul class="mt-10 grid gap-4 sm:grid-cols-2">
        <li class="rounded-xl border border-border/70 bg-page p-5">
          <a href={withBase('/research/themes')} class="font-serif text-lg font-semibold text-ink no-underline hover:text-primary">
            Research themes →
          </a>
          <p class="mt-2 text-sm text-muted">Assessment for learning, multilingual higher education, motivation, GenAI, and pedagogy.</p>
        </li>
        <li class="rounded-xl border border-border/70 bg-page p-5">
          <a
            href={withBase('/research/publications')}
            class="font-serif text-lg font-semibold text-ink no-underline hover:text-primary"
          >
            Publications →
          </a>
          <p class="mt-2 text-sm text-muted">Peer-reviewed articles, dissertation, DOIs, and manuscripts under review.</p>
        </li>
        <li class="rounded-xl border border-border/70 bg-page p-5 sm:col-span-2">
          <a href={withBase('/research/funding')} class="font-serif text-lg font-semibold text-ink no-underline hover:text-primary">
            Funded projects →
          </a>
          <p class="mt-2 text-sm text-muted">Grants and collaborative projects on assessment and language education.</p>
        </li>
      </ul>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
