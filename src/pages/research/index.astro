---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import MainWithAside from '../../components/MainWithAside.astro';
import ResearchSectionAside from '../../components/ResearchSectionAside.astro';
import ResearchMap from '../../components/ResearchMap.astro';
import { person } from '../../data/cv';

const title = `Research · ${person.fullDisplayName}`;
const description = `Research interests, publications, and funded projects — ${person.fullDisplayName}.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-page">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Research</h1>
      <MainWithAside asideLabel="Research menu" wide>
        <div>
          <ResearchMap class="mt-4" />
        </div>
        <ResearchSectionAside slot="aside" />
      </MainWithAside>
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
