---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageShell from '../../components/PageShell.astro';
import SectionSubnav from '../../components/SectionSubnav.astro';
import GrantsTable from '../../components/GrantsTable.astro';
import { researchSubnav } from '../../data/sectionNav';
import { person } from '../../data/cv';

const title = `Funded projects · ${person.fullDisplayName}`;
const description = `Research funding and collaborative projects — ${person.fullDisplayName}.`;
---

<BaseLayout {title} {description}>
  <SiteHeader />
  <main id="main-content" class="min-h-[50vh] w-full bg-surface">
    <PageShell accentBar>
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">Funded projects</h1>
      <SectionSubnav ariaLabel="Research section" items={researchSubnav} />
      <GrantsTable />
    </PageShell>
  </main>
  <SiteFooter />
</BaseLayout>
